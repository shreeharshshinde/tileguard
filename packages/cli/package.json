{
  "name": "tileguard",
  "version": "0.4.1",
  "description": "Command-line interface for TileGuard — geospatial quality analysis framework",
  "type": "module",
  "bin": {
    "tileguard": "./dist/bin.js"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "tileguard",
    "cli",
    "geospatial",
    "validation"
  ],
  "license": "MIT",
  "dependencies": {
    "@tileguard/config": "workspace:*",
    "@tileguard/core": "workspace:*",
    "@tileguard/reporters": "workspace:*",
    "@tileguard/tile-rules": "workspace:*",
    "@tileguard/style-rules": "workspace:*",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "5.4.5",
    "vitest": "^1.6.0"
  }
}
